# Function to create the Gapminder Bubble Plot
make_bubble_plot <- function(data_to_plot, x_var) {
plot_ly(
data_to_plot,
x = ~get(x_var),           # Use get() so we can switch between income/education
y = ~babies_per_woman,
size = ~population,        # This makes it a BUBBLE chart
color = ~religion,         # Colors bubbles by religion
type = "scatter",          # Required for bubbles
mode = "markers",          # Required for bubbles
sizes = c(10, 50),         # Controls the min/max bubble size
text = ~paste0("<b>", name, "</b><br>",
"Year: ", year, "<br>",
"Fertility: ", babies_per_woman, "<br>",
"Pop: ", scales::comma(population)),
hoverinfo = "text",
marker = list(opacity = 0.7, sizemode = 'diameter', line = list(width = 1, color = '#FFFFFF'))
) |>
layout(
xaxis = list(
title = ifelse(x_var == "income", "Daily Income (Log Scale)", "Years of Schooling"),
type = ifelse(x_var == "income", "log", "linear"), # Auto-switch to log scale
tickprefix = ifelse(x_var == "income", "$", "")
),
yaxis = list(title = "Babies per Woman"),
paper_bgcolor = "#ffffff",
plot_bgcolor  = "#fafafa",
margin = list(l = 50, r = 50, t = 50, b = 50)
) |>
config(displayModeBar = FALSE)
}
View(make_bubble_plot)
runApp()
