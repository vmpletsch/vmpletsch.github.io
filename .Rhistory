"Religion: ", religion, "<br>",
x_label, ": ", round(.data[[x_var]], 2), "<br>",
"Fertility: ", babies_per_woman))) +
geom_smooth(method = "lm", se = FALSE, color = "black", linetype = "dashed", size = 0.5) +
